# ============================================================
# Lead Intelligence OS — Backend Environment Variables Template
# ============================================================

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DATABASE_PATH=./data/leads.db

# CORS / Frontend Domain
FRONTEND_URL=http://localhost:3000

# Google Gemini API (Required for AI ranking & suggestions)
GEMINI_API_KEY=your_gemini_api_key_here

# Apify API Token (Required for cloud-based Google Maps scraping)
APIFY_API_TOKEN=your_apify_api_token_here

# Firecrawl API Key (Required for scraping/enriching email/instagram from business websites)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Anthropic Claude API Key (Optional / Future LLM integrations)
CLAUDE_API_KEY=your_claude_api_key_here
