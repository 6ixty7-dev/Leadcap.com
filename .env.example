# ============================================================
# Lead Intelligence OS — Master Environment Variables Example
# ============================================================
# Copy this file's segments to backend/.env and frontend/.env.local respectively.

# ------------------------------------------------------------
# 1. BACKEND PORTION (Save as: backend/.env)
# ------------------------------------------------------------
BACKEND_PORT=3001
BACKEND_NODE_ENV=development
BACKEND_DATABASE_PATH=./data/leads.db
BACKEND_FRONTEND_URL=http://localhost:3000

# API Credentials (Replace with your actual keys)
GEMINI_API_KEY=your_gemini_api_key_here
APIFY_API_TOKEN=your_apify_api_token_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here


# ------------------------------------------------------------
# 2. FRONTEND PORTION (Save as: frontend/.env.local)
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api
